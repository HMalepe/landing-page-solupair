{
  "compatibility_date": "2025-09-24",
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "solupair-landing",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": ".output/server/index.mjs",
  "assets": {
    "binding": "ASSETS",
    "directory": ".output/public"
  },
  "no_bundle": true,
  "rules": [
    {
      "type": "ESModule",
      "globs": [
        "**/*.mjs",
        "**/*.js"
      ]
    }
  ],
  "workers_dev": true,
  "routes": [
    {
      "pattern": "solupair.co.za",
      "custom_domain": true
    },
    {
      "pattern": "www.solupair.co.za",
      "custom_domain": true
    }
  ]
}
