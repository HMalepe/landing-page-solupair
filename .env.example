# Public site URL (optional override; default is https://solupair.co.za in src/lib/site.ts)
# VITE_SITE_URL=https://solupair.co.za

# Supabase (optional — enable when connecting auth / contact forms)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=
